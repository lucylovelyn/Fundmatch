# Copy this file to .env and fill in your values
# Never commit .env to git

# Your wallet private key (no 0x prefix needed by some tools, include it to be safe)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Base Sepolia RPC — default public endpoint works, or use Alchemy/Infura for reliability
BASESEPOLIA_RPC_URL=https://sepolia.base.org

# Contract addresses — filled in after deployment
FOUNDER_REGISTRY_ADDRESS=
INVESTOR_REGISTRY_ADDRESS=
MATCH_ENGINE_ADDRESS=

# Optional: Basescan API key for contract verification
BASESCAN_API_KEY=
